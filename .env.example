# Copy this file to .env before running Docker.

# Local development and production.
# Generate with: openssl rand -base64 32
JWT_SECRET=replace_this_with_a_real_32_byte_base64_secret

# Production only.
# Example: sneaky.yourdomain.com
DOMAIN=

# Production database password.
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=

# Keep production catalog seeding off unless you intentionally want demo products.
APP_SEED_PRODUCTS_ENABLED=false
